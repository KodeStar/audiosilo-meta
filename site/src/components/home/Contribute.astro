---
import Icon from '../Icon.astro'

const REPO = 'https://github.com/kodestar/audiosilo-meta'

const cards = [
  {
    icon: 'edit',
    title: 'Characters and recaps',
    body: 'See which books still need a spoiler-aware character guide or a story-so-far recap, then write one in your own words with the guided builder.',
    cta: 'See what needs work',
    href: '/contribute',
    external: false,
  },
  {
    icon: 'database',
    title: 'Import your library',
    body: 'Drop an OpenAudible or Libation export - or a folder scan - and check what is already catalogued, right in your browser. Then contribute the new books.',
    cta: 'Open the import tool',
    href: '/import',
    external: false,
  },
  {
    icon: 'edit',
    title: 'Add or fix data',
    body: 'Spotted a missing narrator, a wrong runtime, or a book that is not here yet? Open an issue form - no JSON required - and it becomes a pull request.',
    cta: 'Open an issue',
    href: `${REPO}/issues/new/choose`,
    external: true,
  },
  {
    icon: 'chat',
    title: 'Join the community',
    body: 'Coordinate contributions, ask for help, and help shape the schema on the AudioSilo Discord and in GitHub Discussions.',
    cta: 'Join the Discord',
    href: 'https://discord.gg/nFFqRbkRn6',
    external: true,
  },
] as const
---

<!-- overflow-hidden clips the full-bleed decorative glow (right-[-8rem] extends
     past the right viewport edge) to this section, so it never adds page-wide
     horizontal scroll. No open dropdown lives here, so clipping the section
     directly is safe (unlike the hero, which needs an inset wrapper). -->
<section id="contribute" class="relative scroll-mt-24 overflow-hidden py-20">
  <div class="glow right-[-8rem] top-10 h-[26rem] w-[26rem]"></div>
  <div class="container relative z-10">
    <div class="reveal mx-auto max-w-2xl text-center">
      <span class="mb-3 block text-xs font-semibold uppercase tracking-[0.2em] text-pink-500">
        Community maintained
      </span>
      <h2 class="text-3xl font-bold tracking-tight text-hi sm:text-4xl">
        The database grows when you contribute
      </h2>
      <p class="mt-4 text-lg leading-relaxed text-body">
        Everything here is real, verifiable and dedicated to the public domain. There
        are no accounts and no gatekeepers - every change goes through GitHub.
      </p>
    </div>

    <div class="reveal mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      {
        cards.map((card) => (
          <div class="flex flex-col rounded-2xl border border-edge bg-surface p-6">
            <span class="inline-flex h-11 w-11 items-center justify-center rounded-xl border border-edge bg-raised text-pink-400">
              <Icon name={card.icon} class="h-5 w-5" />
            </span>
            <h3 class="mt-5 text-lg font-semibold text-hi">{card.title}</h3>
            <p class="mt-3 flex-grow text-sm leading-relaxed text-body">{card.body}</p>
            <a
              href={card.href}
              {...(card.external ? { target: '_blank', rel: 'noopener' } : {})}
              class="mt-5 inline-flex items-center gap-1.5 text-sm font-medium text-pink-400 transition-colors hover:text-pink-300"
            >
              {card.cta}
              <Icon name="arrowRight" class="h-4 w-4" />
            </a>
          </div>
        ))
      }
    </div>

    <!-- The one restrained pink CTA moment. -->
    <div class="reveal mt-14">
      <div
        class="relative overflow-hidden rounded-2xl border border-pink-500/30 bg-gradient-to-br from-pink-600/20 to-pink-600/5 px-6 py-10 text-center sm:px-10"
      >
        <h3 class="text-2xl font-bold tracking-tight text-hi sm:text-3xl">
          Help build the audiobook database that should already exist
        </h3>
        <p class="mx-auto mt-3 max-w-xl text-body">
          Open, audiobook-first, and free for anyone to use - starting with the
          narrators, recordings and chapters every other database leaves out.
        </p>
        <div class="mt-7 flex flex-wrap items-center justify-center gap-3">
          <a
            href={REPO}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center justify-center gap-2 rounded-lg bg-pink-600 px-6 py-3 font-medium text-white shadow-lg shadow-pink-600/20 transition-all duration-200 hover:-translate-y-0.5 hover:bg-pink-500"
          >
            <Icon name="github" class="h-5 w-5" />
            Explore the repository
          </a>
          <a
            href={`${REPO}/blob/main/CONTRIBUTING.md`}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center justify-center gap-2 rounded-lg border border-edge px-6 py-3 font-medium text-hi transition-all duration-200 hover:-translate-y-0.5 hover:border-pink-500"
          >
            How to contribute
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

---
import Base from '../layouts/Base.astro'
import Waveform from '../components/Waveform.astro'
---

<Base title="Not found - AudioSilo Meta" description="This page could not be found.">
  <section class="relative overflow-hidden">
    <div class="glow left-1/2 top-0 h-[24rem] w-[24rem] -translate-x-1/2"></div>
    <div class="container relative z-10 py-24 text-center sm:py-32">
      <p class="text-6xl font-black tracking-tight text-edge sm:text-7xl">404</p>
      <h1 class="mt-4 text-2xl font-bold text-hi sm:text-3xl">This chapter doesn't exist</h1>
      <p class="mx-auto mt-3 max-w-md text-body">
        The page you were after is not in the database. Try a search, or head back to the
        start.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a
          href="/"
          class="inline-flex items-center justify-center gap-2 rounded-lg bg-pink-600 px-6 py-3 font-medium text-white shadow-lg shadow-pink-600/20 transition-all duration-200 hover:-translate-y-0.5 hover:bg-pink-500"
        >
          Back to search
        </a>
      </div>
      <Waveform bars={40} class="mx-auto mt-14 max-w-md opacity-50" />
    </div>
  </section>
</Base>

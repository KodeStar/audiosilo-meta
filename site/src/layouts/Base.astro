---
import '@fontsource/roboto/400.css'
import '@fontsource/roboto/500.css'
import '@fontsource/roboto/700.css'
import '@fontsource/roboto/900.css'
import '../styles/global.css'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'

interface Props {
  title?: string
  description?: string
  /** Set on pages whose first section manages its own generous top spacing
      (home). Plain content pages leave it false so <main> gets a spacer that
      clears the sticky header. */
  hasHero?: boolean
}

const {
  title = 'AudioSilo Meta - the open audiobook metadata database',
  description = 'An open, community-maintained database of audiobooks - works, recordings, narrators, series and chapters. Free to use, dedicated to the public domain (CC0), built by listeners.',
  hasHero = false,
} = Astro.props

const canonical = new URL(Astro.url.pathname, Astro.site).href
const ogImage = new URL('/android-chrome-512x512.png', Astro.site).href
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <!-- Mark the document JS-capable early so scroll-reveal styles (scoped to
         `.js .reveal`) only hide content when they can also un-hide it. -->
    <script is:inline>
      document.documentElement.classList.add('js')
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color="#db2777" />
    <meta name="theme-color" content="#0b111b" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="AudioSilo Meta" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body class="bg-deep text-body min-h-screen flex flex-col">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-[100] focus:rounded-md focus:bg-pink-600 focus:px-4 focus:py-2 focus:text-white"
    >
      Skip to content
    </a>
    <Header />
    <main id="main" class:list={['flex-grow', !hasHero && 'pt-10 sm:pt-14']}>
      <slot />
    </main>
    <Footer />

    <!-- Scroll-reveal: add `is-visible` once, then stop observing. Reveals
         everything immediately under prefers-reduced-motion. -->
    <script>
      const reveals = document.querySelectorAll<HTMLElement>('.reveal')
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches
      if (reduce || !('IntersectionObserver' in window)) {
        reveals.forEach((el) => el.classList.add('is-visible'))
      } else {
        const io = new IntersectionObserver(
          (entries, observer) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible')
                observer.unobserve(entry.target)
              }
            })
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.05 }
        )
        reveals.forEach((el) => io.observe(el))
      }
    </script>
  </body>
</html>

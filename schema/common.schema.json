{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meta.audiosilo.app/schema/common.schema.json",
  "title": "AudioSilo metadata - shared definitions",
  "$defs": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "maxLength": 100
    },
    "license": {
      "type": "string",
      "enum": ["CC0-1.0"]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "user",
            "openaudible-import",
            "libation-import",
            "audible-lookup",
            "openlibrary",
            "wikidata",
            "inventaire",
            "community"
          ]
        },
        "ref": {
          "type": "string"
        },
        "imported_at": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "common.schema.json#/$defs/source"
      }
    },
    "language": {
      "type": "string",
      "pattern": "^[a-z]{2,3}(-[a-z0-9]{2,8})*$"
    },
    "isbn": {
      "type": "string",
      "pattern": "^(\\d{9}[0-9Xx]|\\d{13})$"
    },
    "isbn_list": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "common.schema.json#/$defs/isbn"
      }
    },
    "asin": {
      "type": "string",
      "pattern": "^[A-Z0-9]{10}$"
    },
    "date_year": {
      "type": "string",
      "pattern": "^\\d{4}(-\\d{2}-\\d{2})?$"
    },
    "date_flex": {
      "type": "string",
      "pattern": "^\\d{4}(-\\d{2}(-\\d{2})?)?$"
    }
  }
}

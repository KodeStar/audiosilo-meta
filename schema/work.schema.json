{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meta.audiosilo.app/schema/work.schema.json",
  "title": "work",
  "description": "An abstract book: title, authors, series membership. Narrations live in sibling recording records.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "authors", "language", "license", "sources"],
  "properties": {
    "id": {
      "$ref": "common.schema.json#/$defs/slug"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "subtitle": {
      "type": "string",
      "minLength": 1
    },
    "authors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "common.schema.json#/$defs/slug"
      }
    },
    "language": {
      "$ref": "common.schema.json#/$defs/language"
    },
    "first_published": {
      "$ref": "common.schema.json#/$defs/date_year"
    },
    "description": {
      "type": "string"
    },
    "xref": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "wikidata": {
          "type": "string",
          "pattern": "^Q\\d+$"
        },
        "openlibrary": {
          "type": "string",
          "pattern": "^OL\\d+W$"
        },
        "goodreads": {
          "type": "string",
          "minLength": 1
        },
        "isbn": {
          "$ref": "common.schema.json#/$defs/isbn_list"
        }
      }
    },
    "license": {
      "$ref": "common.schema.json#/$defs/license"
    },
    "sources": {
      "$ref": "common.schema.json#/$defs/sources"
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meta.audiosilo.app/schema/series.schema.json",
  "title": "series",
  "description": "An ordered set of works.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "works", "license", "sources"],
  "properties": {
    "id": {
      "$ref": "common.schema.json#/$defs/slug"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "authors": {
      "type": "array",
      "items": {
        "$ref": "common.schema.json#/$defs/slug"
      }
    },
    "works": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["work", "position"],
        "properties": {
          "work": {
            "$ref": "common.schema.json#/$defs/slug"
          },
          "position": {
            "type": "string",
            "pattern": "^\\d+(\\.\\d+)?$"
          }
        }
      }
    },
    "xref": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "wikidata": {
          "type": "string",
          "pattern": "^Q\\d+$"
        },
        "goodreads": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "license": {
      "$ref": "common.schema.json#/$defs/license"
    },
    "sources": {
      "$ref": "common.schema.json#/$defs/sources"
    }
  }
}

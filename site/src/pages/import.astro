---
import Base from '../layouts/Base.astro'
import ImportTool from '../components/import/ImportTool.tsx'

const REPO = 'https://github.com/kodestar/audiosilo-meta'
---

<Base
  title="Import your library - AudioSilo Meta"
  description="Drop your OpenAudible export to see which of your audiobooks are already in the open metadata database and which are new - checked entirely in your browser. Only ASINs and ISBNs are sent to the API."
>
  <section class="relative pb-20">
    <div class="glow left-[-8rem] top-0 h-[26rem] w-[26rem]"></div>
    <div class="container relative z-10">
      <div class="reveal mx-auto max-w-2xl text-center">
        <span
          class="mb-3 block text-xs font-semibold uppercase tracking-[0.2em] text-pink-500"
        >
          Contribute
        </span>
        <h1 class="text-3xl font-bold tracking-tight text-hi sm:text-4xl">
          Import your library
        </h1>
        <p class="mt-4 text-lg leading-relaxed text-body">
          Drop your OpenAudible <code class="text-pink-300">books.json</code> and this
          page checks, entirely in your browser, which of your audiobooks are already in
          the open database and which are new. Your file never leaves your device - only
          ASINs and ISBNs are sent to the API to look for a match.
        </p>
        <p class="mt-3 text-sm leading-relaxed text-dim">
          Everything you contribute here is factual metadata dedicated to the public
          domain (CC0). See the
          <a
            href={`${REPO}/blob/main/CONTRIBUTING.md`}
            target="_blank"
            rel="noopener"
            class="text-pink-400 transition-colors hover:text-pink-300">contributing guide</a
          >
          and the
          <a
            href={`${REPO}/blob/main/LICENSING.md`}
            target="_blank"
            rel="noopener"
            class="text-pink-400 transition-colors hover:text-pink-300">licensing terms</a
          >.
        </p>
      </div>

      <div class="reveal mx-auto mt-10 max-w-2xl">
        <ImportTool client:only="react" />
      </div>
    </div>
  </section>
</Base>
